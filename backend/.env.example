OPENAI_API_KEY=sk-your-openai-key-here
DATABASE_URL=postgresql://user:password@localhost:5432/applyai
JWT_SECRET=some-long-random-string-change-this
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
# Required for “Continue with Google” redirect flow (in-app browsers). Create a Web client secret in Google Cloud.
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Callback URL must match Google Cloud → Authorized redirect URIs, e.g. https://YOUR_DOMAIN/auth/google/callback
# Optional: comma-separated list to allow multiple origins (overrides FRONTEND_URL-based default)
# GOOGLE_OAUTH_REDIRECT_URIS=https://app.example.com/auth/google/callback,http://localhost:3000/auth/google/callback
# Optional: allow any https://*.vercel.app/auth/google/callback (set only if you register each preview URL in Google Cloud)
# ALLOW_VERCEL_PREVIEW_OAUTH=1
